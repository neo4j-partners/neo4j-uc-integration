# sample-validation — Configuration
# Copy to .env and fill in your values:
#   cp .env.sample .env

# =============================================================================
# databricks-job-runner core keys
# =============================================================================

# CLI profile name (configured via: databricks configure --profile <name>)
DATABRICKS_PROFILE=

# Compute mode: cluster (default) or serverless
DATABRICKS_COMPUTE_MODE=cluster

# Existing all-purpose cluster ID (required when DATABRICKS_COMPUTE_MODE=cluster)
DATABRICKS_CLUSTER_ID=

# Remote workspace path where scripts are uploaded
DATABRICKS_WORKSPACE_DIR=/Users/<your-email>/sample_validation

# =============================================================================
# Neo4j Aura Credentials
# =============================================================================
# These are stored as Databricks Secrets and never passed as plaintext params.
# Run ./create_secrets.sh to provision the secret scope from these values.

NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Databricks secret scope (must match SECRET_KEYS in cli/__init__.py)
DATABRICKS_SECRET_SCOPE=sample_validation

# =============================================================================
# Unity Catalog
# =============================================================================

# Unity Catalog catalog name
UC_CATALOG=

# Schema name
UC_SCHEMA=neo4j_getting_started

# Volume name for CSV data files (populated by upload_data.sh)
UC_VOLUME=aircraft_data

# Path to the neo4j-unity-catalog-connector JAR in a UC Volume
JDBC_JAR_PATH=/Volumes/<catalog>/<schema>/<volume>/neo4j-unity-catalog-connector.jar

# UC connection name for JDBC
UC_CONNECTION_NAME=sample_neo4j_jdbc_connection
