# sample-validation — Configuration
# Copy to .env and fill in your values:
#   cp .env.sample .env

# =============================================================================
# Databricks Connection (required)
# =============================================================================

# CLI profile name (configured via: databricks configure --profile <name>)
DATABRICKS_PROFILE=""

# Existing all-purpose cluster ID to run jobs on (must be running or auto-startable)
DATABRICKS_CLUSTER_ID=""

# Remote workspace path where scripts are uploaded
WORKSPACE_DIR="/Workspace/Users/your-email/sample_validation"

# =============================================================================
# Neo4j Aura Credentials (required)
# =============================================================================

NEO4J_URI="neo4j+s://xxxxxxxx.databases.neo4j.io"
NEO4J_USERNAME="neo4j"

# Option 1 (recommended): Use Databricks Secrets
# Create the secret:  databricks secrets put-secret --profile <profile> <scope> neo4j-password
NEO4J_SECRET_SCOPE=""
NEO4J_SECRET_KEY="neo4j-password"

# Option 2: Direct password (visible in job parameters — use secrets in production)
NEO4J_PASSWORD=""

# =============================================================================
# Databricks Unity Catalog (required)
# =============================================================================

# Unity Catalog catalog name
UC_CATALOG=""

# Schema name (default: neo4j_getting_started)
UC_SCHEMA="neo4j_getting_started"

# Volume name for CSV data files
UC_VOLUME="data"

# Path to the neo4j-unity-catalog-connector JAR in a UC Volume
JDBC_JAR_PATH="/Volumes/<catalog>/<schema>/<volume>/neo4j-unity-catalog-connector.jar"

# UC connection name for JDBC
UC_CONNECTION_NAME="sample_neo4j_jdbc_connection"
