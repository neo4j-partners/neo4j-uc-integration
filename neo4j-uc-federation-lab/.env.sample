# Neo4j Connection Credentials
# These are loaded into Databricks secrets by setup.sh

# Neo4j host (without protocol prefix)
# e.g., for "neo4j+s://example.databases.neo4j.io" use "example.databases.neo4j.io"
NEO4J_HOST=your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# Optional: database name (defaults to "neo4j")
NEO4J_DATABASE=neo4j

# Unity Catalog connection name (workspace-level, NOT catalog.schema scoped)
# Just use the connection name as shown in SHOW CONNECTIONS
UC_CONNECTION_NAME=neo4j_connection

# Path to Neo4j JDBC Lakehouse Federation Connector JAR in Unity Catalog Volume
# Upload the JAR to your UC Volume, then set the path here
JDBC_JAR_PATH=/Volumes/uc-w-neo4j/jdbc_drivers/jars/neo4j-unity-catalog-connector-1.3.1.jar

# Lakehouse catalog and schema containing Delta tables (sensor_readings, aircraft, etc.)
LAKEHOUSE_CATALOG=your-catalog-name
LAKEHOUSE_SCHEMA=lakehouse
